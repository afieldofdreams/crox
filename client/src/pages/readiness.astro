---
import Base from '../layouts/Base.astro';
import FaqAccordion from '../components/FaqAccordion.tsx';

const faqs = [
	{
		q: 'How is this different from a free discovery call?',
		a: "A discovery call is 30 minutes and produces a recommendation. A Readiness Assessment is three weeks and produces a written report you can take to a board. Different artefacts, different depth.",
	},
	{
		q: "How much of our team's time does this take?",
		a: "Roughly 4–6 hours total across three weeks. Mostly week 1 interviews and a one-hour walkthrough at the end.",
	},
	{
		q: "What if the report just tells us we're not ready?",
		a: "Then you've spent £5,000 to avoid spending £50,000 on something that wouldn't have worked. The report tells you what you'd need to change first, in what order.",
	},
	{
		q: 'Do you cover specific regulations (HIPAA, GDPR, FCA)?',
		a: "We address regulatory exposure relevant to your sector and flag where specialist counsel is needed. We're not a law firm — we work alongside one if you have one.",
	},
	{
		q: 'Can the report inform a tender or board paper?',
		a: "Yes. It's written to be quotable in board papers and procurement documents. Specific, plain-language, and dated.",
	},
];

const jsonLd = [
	{
		'@context': 'https://schema.org',
		'@type': 'Service',
		name: 'AI Readiness Assessment',
		description: 'A three-week assessment of your data, processes, team capability, and risk exposure, with a written report and prioritised next steps.',
		provider: { '@type': 'Organization', name: 'Crox', url: 'https://crox.io' },
		url: 'https://crox.io/readiness',
		areaServed: 'GB',
		offers: {
			'@type': 'Offer',
			price: '5000',
			priceCurrency: 'GBP',
		},
	},
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: faqs.map(faq => ({
			'@type': 'Question',
			name: faq.q,
			acceptedAnswer: { '@type': 'Answer', text: faq.a },
		})),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://crox.io' },
			{ '@type': 'ListItem', position: 2, name: 'Readiness', item: 'https://crox.io/readiness' },
		],
	},
];
---

<Base
	title="AI Readiness Assessment — Know where you stand before you spend | Crox"
	description="A three-week assessment of your data, processes, team, and risk exposure. Written report. Prioritised next steps. £5,000."
	canonical="https://crox.io/readiness"
	jsonLd={jsonLd}
>
	<!-- Hero -->
	<div class="py-24 pb-16 border-b border-border">
		<div class="grid grid-cols-1 md:grid-cols-[1fr_280px] gap-8 lg:gap-12 items-stretch">
			<div>
				<p class="font-mono text-[0.7rem] tracking-[0.2em] uppercase text-accent mb-6">Service</p>
				<h1 class="font-serif font-normal text-[3.2rem] leading-[1.15] mb-8 max-sm:text-[2.2rem]">
					AI Readiness <em class="italic text-accent">Assessment.</em>
				</h1>
				<p class="text-[1rem] text-fg-dim leading-[1.8] mb-10">
					Know exactly where you stand before you spend anything significant.
				</p>
				<div class="flex flex-wrap gap-x-8 gap-y-3 mb-10 font-mono text-[0.85rem]">
					<span class="text-fg">£5,000</span>
					<span class="text-fg-dim">1–2 people from you</span>
					<span class="text-fg-dim">2–3 weeks</span>
				</div>
				<a
					href="/contact"
					class="inline-block font-mono text-[0.8rem] font-medium tracking-[0.15em] uppercase text-fg bg-accent px-10 py-4 transition-all hover:bg-[#c4472e] hover:-translate-y-px no-underline"
				>
					Start with a conversation &rarr;
				</a>
			</div>
			<div class="hidden md:block relative bg-surface border border-border overflow-hidden">
				<svg viewBox="0 0 300 220" style="position: absolute; inset: 0; width: 100%; height: 100%;" preserveAspectRatio="xMidYMid slice">
				  <defs>
				    <pattern id="r-grid" patternUnits="userSpaceOnUse" width="20" height="20">
				      <path d="M 20 0 L 0 0 0 20" fill="none" stroke="#332e2b" stroke-width="0.5"/>
				    </pattern>
				  </defs>
				  <rect x="0" y="0" width="300" height="220" fill="url(#r-grid)" opacity="0.35"/>
				  <polygon points="-20,250 180,-30 320,30 320,250" fill="#c4472e" opacity="0.12"/>
				  <rect x="-10" y="30" width="180" height="14" fill="#e07070" transform="rotate(-8, 80, 37)"/>
				  <text x="180" y="65" font-family="DM Mono, monospace" font-size="68" font-weight="500" fill="#e8e4de" letter-spacing="2">01</text>
				  <g font-family="DM Mono, monospace" font-size="10" letter-spacing="1.5">
				    <g transform="translate(20, 105)">
				      <rect x="0" y="-9" width="11" height="11" fill="none" stroke="#e07070" stroke-width="2"/>
				      <line x1="2" y1="-7" x2="9" y2="0" stroke="#e07070" stroke-width="2.5"/>
				      <line x1="9" y1="-7" x2="2" y2="0" stroke="#e07070" stroke-width="2.5"/>
				      <text x="20" y="0" fill="#d0cbc5">DATA · AUDIT</text>
				      <text x="240" y="0" fill="#e07070" text-anchor="end">CMPL</text>
				    </g>
				    <g transform="translate(20, 130)">
				      <rect x="0" y="-9" width="11" height="11" fill="none" stroke="#c4472e" stroke-width="2"/>
				      <polyline points="2,-3 5,1 9,-6" fill="none" stroke="#c4472e" stroke-width="2.5"/>
				      <text x="20" y="0" fill="#d0cbc5">PROC · MAPPED</text>
				      <text x="240" y="0" fill="#c4472e" text-anchor="end">CMPL</text>
				    </g>
				    <g transform="translate(20, 155)">
				      <rect x="0" y="-9" width="11" height="11" fill="none" stroke="#9d6b53" stroke-width="2"/>
				      <line x1="2" y1="-3" x2="9" y2="-3" stroke="#9d6b53" stroke-width="2.5"/>
				      <text x="20" y="0" fill="#d0cbc5">RISK · REVIEW</text>
				      <text x="240" y="0" fill="#9d6b53" text-anchor="end">PEND</text>
				    </g>
				    <g transform="translate(20, 180)">
				      <rect x="0" y="-9" width="11" height="11" fill="#12100e" stroke="#5a5550" stroke-width="2"/>
				      <text x="20" y="0" fill="#d0cbc5" opacity="0.5">TEAM · BRIEF</text>
				      <text x="240" y="0" fill="#5a5550" text-anchor="end" opacity="0.6">—</text>
				    </g>
				  </g>
				  <g stroke="#e07070" stroke-width="1.5" fill="none">
				    <line x1="275" y1="195" x2="290" y2="195"/>
				    <line x1="290" y1="195" x2="290" y2="210"/>
				  </g>
				</svg>
			</div>
		</div>
	</div>

	<!-- Problem -->
	<section class="py-16 border-b border-border">
		<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
			The problem this solves
			<span class="flex-1 h-px bg-border"></span>
		</div>

		<div class="text-[0.95rem] text-fg-dim leading-[1.8] space-y-4">
			<p>
				You know you need to do something with AI. You don't know what, you don't know in
				what order, and you don't know what could go wrong. Every consultant tells you
				something different. Every vendor demo looks impressive. None of it tells you
				whether your business is actually ready.
			</p>
			<p class="text-fg">
				Spending £50,000 to find out you weren't is the expensive way to learn.
			</p>
		</div>
	</section>

	<!-- What you get -->
	<section class="py-16 border-b border-border">
		<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
			What you get
			<span class="flex-1 h-px bg-border"></span>
		</div>

		<ul class="space-y-4">
			<li class="text-[0.95rem] text-fg-dim leading-[1.7] pl-4 border-l-2 border-accent">
				A written readiness report covering your data, processes, team capability, and risk exposure
			</li>
			<li class="text-[0.95rem] text-fg-dim leading-[1.7] pl-4 border-l-2 border-accent">
				A risk register naming the specific things that could go wrong in your context
			</li>
			<li class="text-[0.95rem] text-fg-dim leading-[1.7] pl-4 border-l-2 border-accent">
				A prioritised list of what to tackle first, second, and not at all
			</li>
			<li class="text-[0.95rem] text-fg-dim leading-[1.7] pl-4 border-l-2 border-accent">
				A clear answer to: should you do an Experiment, more education, or wait
			</li>
		</ul>
	</section>

	<!-- How it works -->
	<section class="py-16 border-b border-border">
		<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
			How it works
			<span class="flex-1 h-px bg-border"></span>
		</div>

		<div class="space-y-10">
			<div class="grid grid-cols-[80px_1fr] gap-4 items-start max-sm:grid-cols-1 max-sm:gap-1">
				<span class="font-mono text-[0.8rem] tracking-[0.1em] uppercase text-accent leading-[1.6]">Week 1</span>
				<div>
					<h3 class="font-serif font-normal text-[1.3rem] leading-[1.3] mb-2">Discovery</h3>
					<p class="text-[0.95rem] text-fg-dim leading-[1.7]">
						Interviews with your operations lead and one technical stakeholder. We review
						your existing tooling, data, and governance setup.
					</p>
				</div>
			</div>

			<div class="grid grid-cols-[80px_1fr] gap-4 items-start max-sm:grid-cols-1 max-sm:gap-1">
				<span class="font-mono text-[0.8rem] tracking-[0.1em] uppercase text-accent leading-[1.6]">Week 2</span>
				<div>
					<h3 class="font-serif font-normal text-[1.3rem] leading-[1.3] mb-2">Analysis</h3>
					<p class="text-[0.95rem] text-fg-dim leading-[1.7]">
						We work through what we've found. You don't do anything in this week.
					</p>
				</div>
			</div>

			<div class="grid grid-cols-[80px_1fr] gap-4 items-start max-sm:grid-cols-1 max-sm:gap-1">
				<span class="font-mono text-[0.8rem] tracking-[0.1em] uppercase text-accent leading-[1.6]">Week 3</span>
				<div>
					<h3 class="font-serif font-normal text-[1.3rem] leading-[1.3] mb-2">Report and walkthrough</h3>
					<p class="text-[0.95rem] text-fg-dim leading-[1.7]">
						Written report delivered. One-hour session to walk you through it and answer questions.
					</p>
				</div>
			</div>
		</div>

		<p class="text-[0.95rem] text-fg-dim leading-[1.7] mt-10 pt-8 border-t border-border">
			Time from you: roughly 4–6 hours total across the three weeks.
		</p>
	</section>

	<!-- Who this is for -->
	<section class="py-16 border-b border-border">
		<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
			Is this for you?
			<span class="flex-1 h-px bg-border"></span>
		</div>

		<div class="grid grid-cols-2 gap-8 max-sm:grid-cols-1">
			<div>
				<h3 class="font-serif font-normal text-[1.2rem] mb-4">Right for you if</h3>
				<ul class="space-y-3">
					<li class="text-[0.95rem] text-fg-dim leading-[1.7] pl-4 border-l-2 border-accent">
						You're being asked by your board, your team, or yourself: what should we be doing with AI?
					</li>
					<li class="text-[0.95rem] text-fg-dim leading-[1.7] pl-4 border-l-2 border-accent">
						You're in a regulated sector (healthcare, legal, financial services, insurance)
					</li>
					<li class="text-[0.95rem] text-fg-dim leading-[1.7] pl-4 border-l-2 border-accent">
						You'd rather spend £5,000 finding out than £50,000 finding out the hard way
					</li>
				</ul>
			</div>
			<div>
				<h3 class="font-serif font-normal text-[1.2rem] mb-4">Not right if</h3>
				<ul class="space-y-3">
					<li class="text-[0.95rem] text-fg-dim leading-[1.7] pl-4 border-l-2 border-border">
						You already know exactly what you want to build and just need someone to build it (skip to <a href="/experiments" class="text-accent no-underline hover:text-fg">Experiments</a>)
					</li>
					<li class="text-[0.95rem] text-fg-dim leading-[1.7] pl-4 border-l-2 border-border">
						You're a sole operator looking for personal productivity tools
					</li>
				</ul>
			</div>
		</div>
	</section>

	<!-- Proof -->
	<section class="py-16 border-b border-border">
		<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
			Proof
			<span class="flex-1 h-px bg-border"></span>
		</div>

		<div class="border-l-2 border-accent pl-6 py-1">
			<p class="font-serif text-[1.3rem] text-fg leading-[1.5] mb-3">
				&ldquo;Extremely knowledgeable who provided fantastic and thorough outputs.&rdquo;
			</p>
			<p class="text-[0.9rem] text-fg-dim">&mdash; Maria Birkmyre, Director</p>
		</div>
	</section>

	<!-- FAQ -->
	<section class="py-16 border-b border-border">
		<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
			Frequently asked questions
			<span class="flex-1 h-px bg-border"></span>
		</div>

		<FaqAccordion faqs={faqs} client:load />
	</section>

	<!-- CTA -->
	<section class="py-24">
		<h2 class="font-serif font-normal text-[2rem] leading-[1.2] mb-6 max-sm:text-[1.6rem]">
			Find out where you actually <em class="italic text-accent">stand.</em>
		</h2>
		<p class="text-[0.95rem] text-fg-dim leading-[1.8] mb-10">
			Three weeks. One report. Clear next steps.
		</p>
		<a
			href="/contact"
			class="inline-block font-mono text-[0.8rem] font-medium tracking-[0.15em] uppercase text-fg bg-accent px-10 py-4 transition-all hover:bg-[#c4472e] hover:-translate-y-px no-underline"
		>
			Start with a conversation &rarr;
		</a>
	</section>
</Base>

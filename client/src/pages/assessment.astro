---
import Base from '../layouts/Base.astro';
import AssessmentQuiz from '../components/AssessmentQuiz.tsx';

// Same env var Base.astro uses for the chat widget — exposed to the
// client via PUBLIC_ prefix (Astro convention).
const chatBaseUrl = import.meta.env.PUBLIC_CHAT_BASE_URL || 'https://chat.crox.io';

const jsonLd = [
	{
		'@context': 'https://schema.org',
		'@type': 'Quiz',
		name: 'AI Readiness Scorecard',
		about: { '@type': 'Thing', name: 'AI adoption readiness' },
		educationalUse: 'Self-assessment',
		provider: { '@type': 'Organization', name: 'Crox', url: 'https://crox.io' },
		url: 'https://crox.io/assessment',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://crox.io' },
			{ '@type': 'ListItem', position: 2, name: 'Scorecard', item: 'https://crox.io/assessment' },
		],
	},
];
---

<Base
	title="AI Readiness Scorecard — Five questions, an honest read | Crox"
	description="A five-question self-assessment of where your organisation actually stands on AI: data, processes, team, governance, and use-case clarity. Free. Two minutes."
	canonical="https://crox.io/assessment"
	jsonLd={jsonLd}
>
	<!-- Hero -->
	<div class="py-24 pb-16">
		<p class="font-mono text-[0.7rem] tracking-[0.2em] uppercase text-accent mb-6">Scorecard</p>
		<h1 class="font-serif font-normal text-[3.2rem] leading-[1.15] mb-8 max-sm:text-[2.2rem]">
			AI Readiness <em class="italic text-accent">Scorecard.</em>
		</h1>
		<p class="text-[1rem] text-fg-dim leading-[1.8] mb-6">
			Five questions. Honest answers. A read on where you actually stand before you spend
			anything on AI.
		</p>
		<div class="flex flex-wrap gap-x-8 gap-y-3 font-mono text-[0.85rem]">
			<span class="text-fg">5 questions</span>
			<span class="text-fg-dim">~2 minutes</span>
			<span class="text-fg-dim">No newsletter sign-up</span>
		</div>
	</div>

	<!-- Quiz -->
	<section class="py-16">
		<AssessmentQuiz client:load chatBaseUrl={chatBaseUrl} />
	</section>
</Base>

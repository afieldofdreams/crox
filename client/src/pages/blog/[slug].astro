---
import Base from '../../layouts/Base.astro';
import { blogPosts, getBlogPostBySlug } from '../../content/blogPosts';
import { ConnectAiPost } from '../../views/blog/ConnectAiPost';
import { AiAccountingPost } from '../../views/blog/AiAccountingPost';
import { AiCrmPost } from '../../views/blog/AiCrmPost';
import { AiSavingTimePost } from '../../views/blog/AiSavingTimePost';
import { AiLegalPost } from '../../views/blog/AiLegalPost';

export function getStaticPaths() {
	return blogPosts.map((post) => ({
		params: { slug: post.slug },
	}));
}

const { slug } = Astro.params;
const post = getBlogPostBySlug(slug);

if (!post) {
	return Astro.redirect('/blog');
}

const baseUrl = 'https://crox.io';
const canonicalUrl = `${baseUrl}/blog/${slug}`;
const dateISO = post.dateISO || '2026-03-15';

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: post.title,
	description: post.description,
	datePublished: dateISO,
	author: {
		'@type': 'Person',
		name: 'Adam Field',
	},
	publisher: {
		'@type': 'Organization',
		name: 'Crox',
		logo: {
			'@type': 'ImageObject',
			url: `${baseUrl}/logo.png`,
		},
	},
	url: canonicalUrl,
	keywords: post.tags.join(', '),
};

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: baseUrl },
		{ '@type': 'ListItem', position: 2, name: 'Insights', item: `${baseUrl}/blog` },
		{ '@type': 'ListItem', position: 3, name: post.title, item: canonicalUrl },
	],
};

const jsonLd = [articleSchema, breadcrumbSchema];

const postComponents: Record<string, any> = {
	'connect-ai-to-business-tools': ConnectAiPost,
	'ai-for-accounting-firms': AiAccountingPost,
	'why-ai-cant-see-your-crm': AiCrmPost,
	'ai-saving-small-business-time': AiSavingTimePost,
	'ai-for-legal-practices': AiLegalPost,
};

const PostContent = postComponents[slug];
---

<Base
	title={`${post.title} — Crox`}
	description={post.description}
	canonical={canonicalUrl}
	ogType="article"
	jsonLd={jsonLd}
	articleMeta={{
		publishedTime: dateISO,
		author: 'Adam Field',
		tags: post.tags,
	}}
>
	<article class="w-full max-w-[900px] mx-auto px-4 sm:px-6 py-16 sm:py-24">
		<!-- Breadcrumb Navigation -->
		<nav aria-label="Breadcrumb" class="mb-12 text-[0.85rem] text-fg-dim">
			<a href="/" class="text-fg border-b border-border pb-px hover:border-accent transition-colors">
				Home
			</a>
			<span class="mx-3" aria-hidden="true">/</span>
			<a href="/blog" class="text-fg border-b border-border pb-px hover:border-accent transition-colors">
				Insights
			</a>
			<span class="mx-3" aria-hidden="true">/</span>
			<span>{post.title}</span>
		</nav>

		<!-- Article Header -->
		<header class="mb-12">
			<h1 class="font-serif font-normal text-[3.2rem] leading-[1.15] text-fg mb-4">
				{post.title}
			</h1>
			<p class="text-[1.1rem] text-fg-dim mb-6">{post.subtitle}</p>

			<div class="flex flex-wrap items-center gap-6 text-[0.85rem] text-fg-dim border-t border-border pt-6">
				<div>
					<span class="text-fg-dim">Published</span>
					<span class="ml-2">{post.date}</span>
				</div>
				<div>
					<span class="text-fg-dim">Read time</span>
					<span class="ml-2">{post.readTime}</span>
				</div>
			</div>
		</header>

		<!-- Article Body -->
		<div class="prose prose-invert max-w-none mb-16">
			<PostContent />
		</div>

		<!-- Bottom CTA Section -->
		<div class="bg-surface border border-border rounded-none p-8 sm:p-10 mb-16">
			<h2 class="font-serif font-normal text-[1.6rem] text-fg mb-4">
				Ready to integrate AI into your business?
			</h3>
			<p class="text-[0.95rem] text-fg-dim leading-[1.8] mb-6">
				See how Model Context Protocol (MCP) can connect your AI assistant to all your business tools. Book a call with our team to discuss your specific needs.
			</p>
			<a
				href="https://calendar.app.google/3avUXyXnctfWpyHF7"
				target="_blank"
				rel="noopener noreferrer"
				class="inline-block font-mono text-[0.8rem] font-medium tracking-[0.15em] uppercase text-fg bg-accent px-10 py-4 hover:opacity-90 transition-opacity"
			>
				Book a Call <span class="sr-only">(opens in a new tab)</span>
			</a>
		</div>

		<!-- More from Insights -->
		<div class="border-t border-border pt-12">
			<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
				More from Insights
				<span class="flex-1 h-px bg-border"></span>
			</div>
			<p class="text-[0.95rem] text-fg-dim">
				Explore more insights and guides.
			</p>
			<a
				href="/blog"
				class="inline-block mt-4 font-mono text-[0.8rem] font-medium tracking-[0.15em] uppercase text-fg border-b border-border pb-px hover:border-accent transition-colors"
			>
				View All Insights
			</a>
		</div>
	</article>
</Base>

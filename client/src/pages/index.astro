---
import Base from '../layouts/Base.astro';

const services = [
	{
		num: '01',
		name: 'Readiness',
		duration: '2–3 WEEKS',
		price: '£5,000',
		blurb: 'Know exactly where you stand before you spend anything. Data, processes, team, risk.',
		bullets: ['Written readiness report', 'Risk register', 'Prioritised next steps'],
		href: '/readiness',
		icon: `<svg viewBox="0 0 36 36" fill="none" stroke="#e07070" stroke-width="2"><rect x="5" y="3" width="18" height="24" rx="1"/><polyline points="9,13 12,16 17,10"/><line x1="20" y1="13" x2="26" y2="13"/><polyline points="9,20 12,23 17,17"/><line x1="20" y1="20" x2="26" y2="20"/></svg>`,
	},
	{
		num: '02',
		name: 'Experiments',
		duration: '4–6 WEEKS',
		price: '£15,000',
		blurb: 'One high-value process, AI-powered, connected to your real systems.',
		bullets: ['Working AI prototype', 'Connected to real systems', 'Governance built in'],
		href: '/experiments',
		icon: `<svg viewBox="0 0 36 36" fill="none" stroke="#e07070" stroke-width="2"><path d="M 14,6 L 14,14 L 6,30 L 30,30 L 22,14 L 22,6 Z"/><line x1="14" y1="6" x2="22" y2="6"/><circle cx="13" cy="22" r="1.5" fill="#e07070"/><circle cx="19" cy="25" r="1.2" fill="#e07070"/><circle cx="16" cy="19" r="1" fill="#e07070"/></svg>`,
	},
	{
		num: '03',
		name: 'Education',
		duration: 'HALF / FULL DAY',
		price: '£3,500',
		blurb: 'Practical training for the people who will use AI day to day.',
		bullets: ['Hands-on, not slideware', 'Sector-specific context', 'Safe usage guidelines'],
		href: '/education',
		icon: `<svg viewBox="0 0 36 36" fill="none" stroke="#e07070" stroke-width="2"><path d="M 4,14 L 18,8 L 32,14 L 18,20 Z"/><path d="M 9,17 L 9,24 Q 18,30 27,24 L 27,17"/><line x1="32" y1="14" x2="32" y2="20"/></svg>`,
	},
	{
		num: '04',
		name: 'Board / Exec',
		duration: 'PROGRAMME',
		price: 'From £2,500',
		blurb: 'Briefings and working sessions for the people deciding what AI does in your organisation.',
		bullets: ['Board-tailored briefings', 'Working sessions', 'Ongoing programme option'],
		href: '/board-exec',
		icon: `<svg viewBox="0 0 36 36" fill="none" stroke="#e07070" stroke-width="2"><path d="M 18,4 L 30,8 L 30,18 Q 30,28 18,32 Q 6,28 6,18 L 6,8 Z"/><polyline points="12,18 16,22 24,14"/></svg>`,
	},
];

const homepageTestimonials = [
	{
		quote: 'Adam cares deeply about the quality and impact of his work.',
		name: 'Jasel Mehta',
		role: 'COO',
	},
	{
		quote: 'Extremely knowledgeable who provided fantastic and thorough outputs.',
		name: 'Maria Birkmyre',
		role: 'Director',
	},
];

const jsonLd = [
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		name: 'Crox',
		url: 'https://crox.io',
		logo: 'https://crox.io/og.png',
		description: 'Crox helps organisations in regulated industries adopt AI safely. Readiness assessments, experiments, education, and board-level guidance.',
		founder: { '@type': 'Person', name: 'Adam Field' },
		sameAs: ['https://linkedin.com/in/afieldio'],
	},
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: 'Crox',
		url: 'https://crox.io',
	},
];
---

<Base
	title="Crox — Practical AI for Regulated Industries"
	description="Readiness, Experiments, Education, and Board-level guidance for organisations adopting AI in regulated sectors. Pricing upfront. No retainers. No ambiguity."
	canonical="https://crox.io/"
	ogType="website"
	jsonLd={jsonLd}
>
	<!-- Hero -->
	<div class="py-24 pb-16 border-b border-border">
		<h1 class="font-serif font-normal text-[3.2rem] leading-[1.15] mb-8 max-sm:text-[2.2rem]">
			Most businesses are doing AI <em class="italic text-accent">wrong.</em>
		</h1>
		<p class="text-[1rem] text-fg-dim leading-[1.8] mb-10">
			Not because they lack ambition. Because nobody told them where to start, what to put
			in place, or how to know if it's actually working.
		</p>
		<div class="flex gap-6 items-center max-sm:flex-col max-sm:items-start">
			<a
				href="/contact"
				class="inline-block font-mono text-[0.8rem] font-medium tracking-[0.15em] uppercase text-fg bg-accent px-10 py-4 transition-all hover:bg-[#c4472e] hover:-translate-y-px no-underline"
			>
				Start with a conversation &rarr;
			</a>
			<a
				href="#briefing"
				class="text-[0.95rem] text-fg no-underline border-b border-border pb-px hover:border-accent transition-colors"
			>
				Read the briefing &rarr;
			</a>
		</div>
	</div>

	<!-- Pain -->
	<section class="py-16 border-b border-border">
		<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
			Sound familiar?
			<span class="flex-1 h-px bg-border"></span>
		</div>

		<div class="text-[0.95rem] text-fg-dim leading-[1.8] space-y-4 mb-10">
			<p>
				You've tried a few AI tools. Maybe ran a pilot. It felt promising, then it stalled.
				Now you have a board asking why you're behind, a team that's sceptical, and no clear
				path forward.
			</p>
			<p class="text-fg">
				The problem isn't the technology. It's the missing layer — governance, guardrails,
				and a realistic plan.
			</p>
		</div>

		<div class="border-l-[3px] border-accent pl-6 py-1">
			<p class="font-serif text-[1.4rem] text-fg leading-[1.4] mb-2">
				&ldquo;He was amazingly fast and uncomplicated in delivering an extensive, clear,
				and detailed report.&rdquo;
			</p>
			<p class="text-[0.9rem] text-fg-dim">&mdash; Romina Buchel, Marketing Manager</p>
		</div>
	</section>

	<!-- Flagship briefing -->
	<section id="briefing" class="py-16 border-b border-border">
		<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
			Briefing &middot; May 2026
			<span class="flex-1 h-px bg-border"></span>
		</div>

		<a href="/insights/static-controls-live-models" class="block bg-surface border border-border p-8 transition-colors hover:border-accent no-underline group">
			<p class="font-mono text-[0.7rem] tracking-[0.2em] uppercase text-accent mb-3">Briefing</p>
			<h2 class="font-serif font-normal text-[1.8rem] mb-4 max-sm:text-[1.4rem] text-fg group-hover:text-accent transition-colors">
				Static Controls, Live Models
			</h2>
			<p class="text-[0.95rem] text-fg-dim leading-[1.7] mb-6">
				A briefing for boards and exec teams adopting AI in regulated industries. Five lenses
				more useful than the conventional checklist, the August 2026 forcing function, and the
				diagnostic question most board packs are missing. Free to read. No email gate. Free to forward.
			</p>
			<span class="font-mono text-[0.8rem] tracking-[0.1em] uppercase text-fg-dim group-hover:text-accent transition-colors">
				Read the briefing &rarr;
			</span>
		</a>
	</section>

	<!-- What we do -->
	<section class="py-16 border-b border-border">
		<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
			What we do
			<span class="flex-1 h-px bg-border"></span>
		</div>

		<h2 class="font-serif font-normal text-[1.6rem] mb-10 max-sm:text-[1.3rem]">
			No retainers. No ambiguity. Here's what it costs.
		</h2>

		<div class="grid grid-cols-2 gap-4 max-sm:grid-cols-1">
			{services.map((s) => (
				<a
					href={s.href}
					class="flex flex-col bg-surface border border-border min-h-[280px] transition-colors hover:border-accent no-underline group"
				>
					<div class="flex justify-between items-start px-5 pt-5">
						<span class="font-mono text-[0.65rem] tracking-[0.25em] text-accent">{s.num} · {s.name.toUpperCase()}</span>
						<span class="font-mono text-[0.55rem] tracking-[0.2em] uppercase text-fg-dim border border-border px-2 py-1">{s.duration}</span>
					</div>
					<div class="px-5 pt-4" set:html={s.icon} />
					<h3 class="font-mono font-medium text-[1rem] tracking-[0.05em] uppercase px-5 pt-4 text-fg group-hover:text-accent transition-colors">{s.name}</h3>
					<p class="text-[0.75rem] leading-[1.6] text-fg-dim px-5 pt-2 flex-1">{s.blurb}</p>
					<ul class="px-5 pt-4 space-y-1">
						{s.bullets.map((b) => (
							<li class="text-[0.7rem] text-fg-dim leading-[1.5] pl-4 relative before:content-['▸'] before:text-accent before:absolute before:left-0">{b}</li>
						))}
					</ul>
					<div class="flex justify-between items-center px-5 py-4 mt-4 border-t border-border">
						<span class="font-mono text-[0.65rem] tracking-[0.2em] uppercase text-accent">{s.price}</span>
						<span class="text-fg text-[0.8rem]">&rarr;</span>
					</div>
				</a>
			))}
		</div>
	</section>

	<!-- Why Crox -->
	<section class="py-16 border-b border-border">
		<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
			Why Crox
			<span class="flex-1 h-px bg-border"></span>
		</div>

		<h2 class="font-serif font-normal text-[1.6rem] mb-6 max-sm:text-[1.3rem]">
			A decade in regulated industries.
		</h2>

		<div class="text-[0.95rem] text-fg-dim leading-[1.8] space-y-4 mb-10">
			<p>
				Healthcare, legal, fintech, insurance. Sectors where getting AI wrong has real
				consequences. That experience is in everything we do.
			</p>
			<p>
				Our founder is a former commercial pilot. Structured thinking, clear decisions,
				no shortcuts.
			</p>
		</div>

		<div class="grid grid-cols-2 gap-6 max-sm:grid-cols-1">
			{homepageTestimonials.map((t) => (
				<div class="border-l-[3px] border-accent pl-6 py-1">
					<p class="font-serif text-[1.4rem] text-fg leading-[1.4] mb-2">
						&ldquo;{t.quote}&rdquo;
					</p>
					<p class="text-[0.9rem] text-fg-dim">&mdash; {t.name}, {t.role}</p>
				</div>
			))}
		</div>
	</section>

	<!-- Latest from Insights -->
	<section class="py-16 border-b border-border">
		<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
			Latest from Insights
			<span class="flex-1 h-px bg-border"></span>
		</div>

		<a href="/insights/second-brain-typed-entities" class="block bg-surface border border-border p-8 transition-colors hover:border-accent no-underline group">
			<div class="flex items-center gap-3 mb-4">
				<span class="text-[0.75rem] font-mono tracking-[0.1em] uppercase text-accent">Essay</span>
				<span class="text-[0.8rem] text-fg-dim">May 2026</span>
			</div>
			<h3 class="font-serif font-normal text-[1.5rem] text-fg mb-3 leading-[1.3] group-hover:text-accent transition-colors max-sm:text-[1.2rem]">
				Why Fibery, Not Obsidian, for My Second Brain
			</h3>
			<p class="text-[0.95rem] text-fg-dim leading-[1.7] mb-4">
				Obsidian thinks in notes. Fibery thinks in typed entities. Why that distinction matters once your second brain has to do real work — and once you want an AI co-pilot to read from it.
			</p>
			<span class="font-mono text-[0.8rem] tracking-[0.1em] uppercase text-fg-dim group-hover:text-accent transition-colors">
				Read the essay &rarr;
			</span>
		</a>
	</section>

	<!-- From the founder -->
	<section class="py-16 border-b border-border">
		<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
			From the founder
			<span class="flex-1 h-px bg-border"></span>
		</div>

		<p class="text-[0.95rem] text-fg-dim leading-[1.8] mb-4">
			Crox was founded by Adam Field — a product leader, former commercial pilot, and builder
			who's spent a decade shipping products where compliance is mandatory and safety is
			critical.
		</p>
		<a href="/about" class="text-[0.95rem] text-accent no-underline hover:text-fg transition-colors">
			More about Adam and why Crox exists &rarr;
		</a>
	</section>

	<!-- Final CTA -->
	<section class="py-24">
		<h2 class="font-serif font-normal text-[2rem] leading-[1.2] mb-6 max-sm:text-[1.6rem]">
			Not sure where to <em class="italic text-accent">start?</em>
		</h2>
		<p class="text-[0.95rem] text-fg-dim leading-[1.8] mb-10">
			Most people aren't. That's what the Readiness Assessment is for.
		</p>
		<a
			href="/contact"
			class="inline-block font-mono text-[0.8rem] font-medium tracking-[0.15em] uppercase text-fg bg-accent px-10 py-4 transition-all hover:bg-[#c4472e] hover:-translate-y-px no-underline"
		>
			Start with a conversation &rarr;
		</a>
	</section>
</Base>

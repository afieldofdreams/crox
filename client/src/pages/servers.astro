---
import Base from '../layouts/Base.astro';
import ServerDirectory from '../components/ServerDirectory.tsx';
import { servers, featuredServer } from '../content/servers';

const baseUrl = 'https://crox.io';
const canonicalUrl = `${baseUrl}/servers`;
const BOOKING_URL = 'https://calendar.app.google/3avUXyXnctfWpyHF7';

const featured = servers.find(s => s.id === featuredServer.serverId);

const collectionPageSchema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: 'MCP Server Directory | Crox',
	description: `Browse ${servers.length}+ MCP servers for AI integration.`,
	url: canonicalUrl,
	isPartOf: {
		'@type': 'Website',
		name: 'Crox',
		url: baseUrl,
	},
};

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: baseUrl },
		{ '@type': 'ListItem', position: 2, name: 'Servers', item: canonicalUrl },
	],
};

const itemListSchema = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	name: 'MCP Servers',
	url: canonicalUrl,
	itemListElement: servers.map((server, index) => ({
		'@type': 'SoftwareApplication',
		position: index + 1,
		name: server.name,
		description: server.description,
		applicationCategory: 'DeveloperApplication',
		...(server.url ? { url: server.url } : {}),
		offers: {
			'@type': 'Offer',
			availability: 'https://schema.org/InStock',
		},
	})),
};

const jsonLd = [collectionPageSchema, breadcrumbSchema, itemListSchema];
---

<Base
	title={`MCP Server Directory — ${servers.length}+ Integrations | Crox`}
	description={`Browse ${servers.length}+ MCP servers for AI integration. Connect Claude and ChatGPT to Slack, GitHub, Salesforce, Stripe, Notion, Figma, and more.`}
	canonical={canonicalUrl}
	jsonLd={jsonLd}
>
	<div class="py-16">
		<!-- Hero Section (static) -->
		<div class="mb-12">
			<h1 class="font-serif text-5xl mb-4 text-fg">
				MCP Server Directory
			</h1>
			<p class="text-[0.95rem] text-fg-dim leading-[1.8] max-w-2xl">
				Browse {servers.length}+ MCP servers that connect AI to your tools, data, and workflows. Each link takes you to the official documentation or repository for that integration.
			</p>
		</div>

		<!-- MCP Server of the Week (static) -->
		{featured && (
			<div class="mb-12 bg-surface border border-accent rounded p-6 md:p-8">
				<div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-4">
					<div>
						<div class="text-[0.7rem] tracking-[0.2em] uppercase text-accent mb-2">
							{featuredServer.headline}
						</div>
						<h2 class="font-serif text-2xl md:text-3xl text-fg">
							{featured.name}
						</h2>
					</div>
					<div class="flex flex-wrap gap-2 items-start">
						<span class="text-[0.75rem] font-mono px-3 py-1 rounded border border-border text-fg-dim">
							{featured.category}
						</span>
						{featured.status === 'official' && (
							<span class="text-[0.75rem] font-mono px-3 py-1 rounded border border-accent text-accent">
								Official
							</span>
						)}
					</div>
				</div>
				<p class="text-[0.95rem] text-fg-dim leading-[1.8] mb-4 max-w-3xl">
					{featuredServer.description}
				</p>
				<div class="flex flex-wrap gap-2 mb-4">
					{featured.tools.map((tool) => (
						<span class="text-[0.8rem] px-2 py-1 bg-bg border border-border rounded text-fg-dim">
							{tool}
						</span>
					))}
				</div>
				{featured.url && (
					<a
						href={featured.url}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-block text-[0.9rem] text-accent hover:text-fg transition-colors font-mono"
					>
						View integration <span class="sr-only">(opens in a new tab)</span> →
					</a>
				)}
			</div>
		)}

		<!-- Interactive search/filter/results (React island) -->
		<ServerDirectory client:load />

		<!-- CTA Section (static) -->
		<div class="border-t border-border pt-12 mt-16">
			<div class="max-w-2xl">
				<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-4">
					Custom Integrations
				</div>
				<h2 class="font-serif text-2xl text-fg mb-4">
					Don't see what you need?
				</h2>
				<p class="text-[0.95rem] text-fg-dim leading-[1.8] mb-6">
					Crox builds custom MCP servers tailored to your specific tools and workflows. Whether it's a proprietary system, legacy database, or niche SaaS platform, we can create connectors that let Claude integrate with your entire tech stack.
				</p>
				<div class="flex gap-4">
					<a
						href="/ai-integration"
						class="inline-block px-6 py-3 bg-accent text-bg font-mono text-[0.9rem] rounded hover:bg-[#d84d2f] transition-colors"
					>
						Explore Custom Builds
					</a>
					<a
						href={BOOKING_URL}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-block px-6 py-3 border border-accent text-accent font-mono text-[0.9rem] rounded hover:bg-accent hover:text-bg transition-colors"
					>
						Schedule a Call <span class="sr-only">(opens in a new tab)</span>
					</a>
				</div>
			</div>
		</div>
	</div>
</Base>

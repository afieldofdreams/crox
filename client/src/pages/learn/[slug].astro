---
export const prerender = true;

import Base from '../../layouts/Base.astro';
import { learnPosts } from '../../content/learnPosts';
import WhatIsMcpPost from '../../views/learn/WhatIsMcpPost';
import McpVsApisPost from '../../views/learn/McpVsApisPost';
import McpArchitecturePost from '../../views/learn/McpArchitecturePost';

export function getStaticPaths() {
	return learnPosts.map((post) => ({
		params: { slug: post.slug },
	}));
}

const { slug } = Astro.params;
const post = learnPosts.find((p) => p.slug === slug);

if (!post) {
	return Astro.redirect('/learn');
}

const baseUrl = 'https://crox.io';
const canonicalUrl = `${baseUrl}/learn/${post.slug}`;

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: post.title,
	description: post.description,
	datePublished: post.dateISO,
	author: {
		'@type': 'Person',
		name: 'Adam Field',
	},
	publisher: {
		'@type': 'Organization',
		name: 'Crox',
		logo: {
			'@type': 'ImageObject',
			url: `${baseUrl}/logo.png`,
		},
	},
	url: canonicalUrl,
	keywords: post.tags.join(', '),
};

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: baseUrl },
		{ '@type': 'ListItem', position: 2, name: 'Learn', item: `${baseUrl}/learn` },
		{ '@type': 'ListItem', position: 3, name: post.title, item: canonicalUrl },
	],
};

const jsonLd = [articleSchema, breadcrumbSchema];

const postComponents: Record<string, any> = {
	'what-is-mcp': WhatIsMcpPost,
	'mcp-vs-apis-vs-plugins': McpVsApisPost,
	'mcp-architecture-explained': McpArchitecturePost,
};

const PostContent = postComponents[slug];

const sortedByDate = [...learnPosts].sort((a, b) =>
	(b.dateISO || '').localeCompare(a.dateISO || '')
);
const currentIdx = sortedByDate.findIndex((p) => p.slug === slug);
const newerPost = currentIdx > 0 ? sortedByDate[currentIdx - 1] : null;
const olderPost =
	currentIdx >= 0 && currentIdx < sortedByDate.length - 1
		? sortedByDate[currentIdx + 1]
		: null;
---

<Base
	title={`${post.title} | Learn | crox`}
	description={post.description}
	canonical={canonicalUrl}
	ogType="article"
	jsonLd={jsonLd}
	articleMeta={{
		publishedTime: post.dateISO,
		author: 'Adam Field',
		tags: post.tags,
	}}
>
	<div class="w-full">
		<section class="w-full px-6 py-16 flex items-center justify-center border-b border-border">
			<div class="w-full max-w-[900px]">
				<div class="mb-8">
					<a
						href="/learn"
						class="text-accent hover:text-fg transition-colors text-[0.9rem] font-mono"
					>
						&larr; Back to Learn
					</a>
				</div>
				<h1 class="font-serif font-normal text-[3.2rem] leading-[1.15] text-fg mb-4">
					{post.title}
				</h1>
				{post.subtitle && (
					<p class="text-[1.1rem] text-accent mb-8">
						{post.subtitle}
					</p>
				)}
				<div class="flex items-center gap-6 text-[0.85rem] text-fg-dim font-mono">
					<span>{post.date}</span>
					<span class="w-px h-4 bg-border"></span>
					<span>{post.readTime}</span>
					<span class="w-px h-4 bg-border"></span>
					<div class="flex gap-2">
						{post.tags.map((tag) => (
							<span
								class="px-2 py-1 border border-border text-fg-dim text-[0.75rem] uppercase tracking-wide"
							>
								{tag}
							</span>
						))}
					</div>
				</div>
			</div>
		</section>

		<section class="w-full px-6 py-16 flex items-center justify-center">
			<div class="w-full max-w-[900px]">
				<PostContent />
			</div>
		</section>

		{(olderPost || newerPost) && (
			<section class="w-full px-6 pb-16 flex items-center justify-center">
				<div class="w-full max-w-[900px]">
					<nav aria-label="Article navigation" class="border-t border-border pt-12">
						<div class="grid grid-cols-2 gap-6 max-sm:grid-cols-1">
							{olderPost ? (
								<a
									href={`/learn/${olderPost.slug}`}
									class="block bg-surface border border-border p-6 transition-colors hover:border-accent no-underline group"
								>
									<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-3">
										&larr; Previous
									</div>
									<h3 class="font-serif font-normal text-[1.2rem] text-fg leading-[1.3] group-hover:text-accent transition-colors">
										{olderPost.title}
									</h3>
								</a>
							) : (
								<span class="hidden sm:block" aria-hidden="true"></span>
							)}
							{newerPost && (
								<a
									href={`/learn/${newerPost.slug}`}
									class="block bg-surface border border-border p-6 transition-colors hover:border-accent no-underline group text-right"
								>
									<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-3">
										Next &rarr;
									</div>
									<h3 class="font-serif font-normal text-[1.2rem] text-fg leading-[1.3] group-hover:text-accent transition-colors">
										{newerPost.title}
									</h3>
								</a>
							)}
						</div>
					</nav>
				</div>
			</section>
		)}

		<!-- Related Content CTA -->
		<section class="w-full px-6 py-24 flex items-center justify-center border-t border-border bg-surface/30">
			<div class="w-full max-w-[900px]">
				<div class="flex flex-col items-center text-center">
					<p class="text-[1rem] text-fg-dim leading-[1.8] mb-8 max-w-[600px]">
						Ready to implement these concepts in your organization? Our team can guide you through the entire MCP integration process.
					</p>
					<a
						href="/ai-integration"
						class="px-8 py-4 bg-accent text-[#0a0a0a] font-mono text-[0.9rem] font-medium hover:opacity-90 transition-opacity"
					>
						Schedule a Consultation
					</a>
				</div>
			</div>
		</section>
	</div>
</Base>

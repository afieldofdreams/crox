# Anthropic — for streaming chat. Haiku 4.5 by default; ~20× cheaper than Opus
# and quality is fine for a marketing-site chat. See memory: feedback-cost-monitoring.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Hard daily input-token budget for /chat. Service refuses new requests once
# crossed (resets UTC midnight). Set this with Haiku pricing in mind: 1M input
# tokens ≈ £0.80, so a budget of 2,000,000 ≈ £1.60/day worst case. The system
# prompt is ~3.5k tokens cached, so a typical conversation reads ~5-10k.
DAILY_INPUT_TOKEN_BUDGET=2000000

# Flight Deck — for /capture to upsert contact via /api/forms
FLIGHT_DECK_BASE_URL=https://flight-deck.crox.io
FORM_CSRF_SECRET=
PROJECT_HOST=crox.io

# Fibery — for appending the transcript to CRM/Contact Activity Stream
FIBERY_HOST=wildgriffin.fibery.io
FIBERY_TOKEN=

# PostHog — server-side event firing on lead capture.
# Must point at the same project as the browser-side snippet in
# client/src/layouts/Base.astro (PUBLIC_POSTHOG_KEY), otherwise the
# /chat capture event and the visitor's pageviews land in different
# projects and the timeline doesn't join up. Crox is on EU cloud.
POSTHOG_HOST=https://eu.i.posthog.com
POSTHOG_PROJECT_API_KEY=

# CORS — origins allowed to call /chat and /capture. Comma-separated.
# Production: https://crox.io,https://www.crox.io
# Dev: http://localhost:3099,http://localhost:4321
CORS_ALLOWED_ORIGINS=http://localhost:3099,https://crox.io,https://www.crox.io

# Where this service runs (for logs / health)
BASE_URL=http://localhost:8001

# Postgres — persists chat conversations + messages for Adam's review.
# Empty in dev = persistence disabled (chat still works). In prod this
# MUST be set so transcripts land somewhere durable.
# Local: postgresql://postgres:postgres@localhost:5432/crox_chat
DATABASE_URL=

# Google Calendar booking link Fred drops at the end of each DODAR
# conversation. Single source of truth — bot is told to use this exact
# URL via prompts/system.md, but we mirror it here so it can be rotated
# without a redeploy if needed (currently informational only).
BOOKING_URL=https://calendar.app.google/dmmq9bdFyc11G8Km8

# Bearer token for /admin/conversations endpoints. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Empty disables the admin routes (they return 503).
ADMIN_TOKEN=

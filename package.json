{
  "name": "crox-monorepo",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev:client": "cd client && npm run dev",
    "setup:server": "cd server && python3 -m venv .venv && .venv/bin/pip install -r requirements.txt",
    "dev:server": "cd server && .venv/bin/python app.py",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}



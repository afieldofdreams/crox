---
import Base from '../layouts/Base.astro';

const BOOKING_URL = 'https://calendar.app.google/3avUXyXnctfWpyHF7';

const testimonials = [
	{
		quote: 'Adam cares deeply about the quality and impact of his work.',
		name: 'Jasel Mehta',
		role: 'COO',
	},
	{
		quote: 'He was amazingly fast and uncomplicated in delivering an extensive, clear, and detailed report.',
		name: 'Romina Buchel',
		role: 'Marketing Manager',
	},
	{
		quote: 'A man of many talents who can focus on the job in hand with precision and get results.',
		name: 'Sam Smith',
		role: 'Design Lead',
	},
	{
		quote: 'He was very professional, I\'d highly recommend on projects that need an eye for detail.',
		name: 'Scott Beat',
		role: 'Quality Manager',
	},
	{
		quote: 'Extremely knowledgeable who provided fantastic and thorough outputs!',
		name: 'Maria Birkmyre',
		role: 'Director',
	},
];

const jsonLd = [
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		name: 'Crox',
		url: 'https://crox.io',
		logo: 'https://crox.io/og.png',
		description: 'Crox helps small and mid-sized businesses connect AI assistants to their existing tools using the Model Context Protocol.',
		founder: { '@type': 'Person', name: 'Adam Field' },
		sameAs: ['https://linkedin.com/in/afieldio'],
	},
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: 'Crox',
		url: 'https://crox.io',
	},
];
---

<Base
	title="Crox — AI That Actually Does Work in Your Business | AI Integration Sprint"
	description="We connect AI to your CRM, accounts, and workflows in two weeks. No more copy-paste. No more isolated chatbots. Real AI integration for small and mid-sized businesses."
	canonical="https://crox.io/"
	ogType="website"
	jsonLd={jsonLd}
>
	<!-- Hero -->
	<div class="py-24 pb-16 border-b border-border">
		<h1 class="font-serif font-normal text-[3.2rem] leading-[1.15] mb-8 max-sm:text-[2.2rem]">
			AI that actually does work in your <em class="italic text-accent">business.</em><br />Not just answers questions.
		</h1>
		<p class="text-[1rem] text-fg-dim leading-[1.8] mb-10">
			We connect AI directly to your business systems — your CRM, accounts, project tools, and data —
			so it can pull real information, take real actions, and save real time. Most businesses are live
			within two weeks.
		</p>
		<a
			href="/ai-integration"
			class="inline-block font-mono text-[0.8rem] font-medium tracking-[0.15em] uppercase text-fg bg-accent px-10 py-4 transition-all hover:bg-[#c4472e] hover:-translate-y-px no-underline"
		>
			Start your AI Integration Sprint &rarr;
		</a>
	</div>

	<!-- The Problem -->
	<section class="py-16 border-b border-border">
		<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
			Most businesses are stuck here
			<span class="flex-1 h-px bg-border"></span>
		</div>

		<div class="grid grid-cols-2 gap-4 max-sm:grid-cols-1">
			<div class="bg-surface border border-border p-6">
				<p class="text-[0.95rem] text-fg-dim leading-[1.7]">Using ChatGPT in isolation — no connection to real business data.</p>
			</div>
			<div class="bg-surface border border-border p-6">
				<p class="text-[0.95rem] text-fg-dim leading-[1.7]">Copying and pasting between tools instead of automating.</p>
			</div>
			<div class="bg-surface border border-border p-6">
				<p class="text-[0.95rem] text-fg-dim leading-[1.7]">No connection to CRM, accounts, or workflows.</p>
			</div>
			<div class="bg-surface border border-border p-6">
				<p class="text-[0.95rem] text-fg-dim leading-[1.7]">No measurable impact — AI feels like a toy, not a tool.</p>
			</div>
		</div>
	</section>

	<!-- AI Integration Sprint — The Spear -->
	<section class="py-16 border-b border-border">
		<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
			AI Integration Sprint
			<span class="flex-1 h-px bg-border"></span>
		</div>

		<div class="bg-surface border-2 border-accent p-8 mb-6">
			<h2 class="font-serif font-normal text-[1.8rem] mb-4 max-sm:text-[1.4rem]">Two weeks. AI connected to your business.</h2>
			<p class="text-[0.95rem] text-fg-dim leading-[1.7] mb-6">
				We connect AI directly to your business systems using the Model Context Protocol so it can:
			</p>
			<div class="grid grid-cols-3 gap-6 mb-6 max-sm:grid-cols-1">
				<div>
					<p class="font-serif text-[1.1rem] text-fg mb-1">Pull real data</p>
					<p class="text-[0.85rem] text-fg-dim leading-[1.6]">From your CRM, accounts, project tools, and databases.</p>
				</div>
				<div>
					<p class="font-serif text-[1.1rem] text-fg mb-1">Take real actions</p>
					<p class="text-[0.85rem] text-fg-dim leading-[1.6]">Create records, send updates, trigger workflows.</p>
				</div>
				<div>
					<p class="font-serif text-[1.1rem] text-fg mb-1">Save real time</p>
					<p class="text-[0.85rem] text-fg-dim leading-[1.6]">Hours back every week for your team, measurably.</p>
				</div>
			</div>
			<a
				href="/ai-integration"
				class="inline-block font-mono text-[0.8rem] font-medium tracking-[0.15em] uppercase text-fg bg-accent px-10 py-4 transition-all hover:bg-[#c4472e] hover:-translate-y-px no-underline"
			>
				Start your AI Integration Sprint &rarr;
			</a>
		</div>
	</section>

	<!-- Supporting Services -->
	<section class="py-16 border-b border-border">
		<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
			Also available
			<span class="flex-1 h-px bg-border"></span>
		</div>

		<div class="grid grid-cols-2 gap-6 max-sm:grid-cols-1">
			<div class="bg-surface border border-border p-8 transition-colors hover:border-accent">
				<h3 class="font-serif font-normal text-[1.3rem] mb-2">AI Strategy Advisory</h3>
				<p class="text-[0.95rem] text-fg-dim leading-[1.7] mb-4">
					Fractional product guidance for founders building AI products or bringing AI into operations.
					Strategy, architecture, and compliance — so you make the right decisions early.
				</p>
				<p class="text-[0.9rem] text-fg-dim leading-[1.6]">
					The strategic layer. Ideal before or alongside an integration sprint.
				</p>
			</div>

			<div class="bg-surface border border-border p-8 transition-colors hover:border-accent">
				<h3 class="font-serif font-normal text-[1.3rem] mb-2">DODAR Workshops</h3>
				<p class="text-[0.95rem] text-fg-dim leading-[1.7] mb-4">
					Half-day sessions teaching your team a structured decision-making framework from aviation.
					Walk away with a repeatable process your team can use every day.
				</p>
				<p class="text-[0.9rem] text-fg-dim leading-[1.6]">
					Team enablement. Up to 15 participants, remote or on-site.
				</p>
			</div>
		</div>
	</section>

	<!-- Why Crox -->
	<section class="py-16 border-b border-border">
		<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
			Why Crox
			<span class="flex-1 h-px bg-border"></span>
		</div>

		<div class="space-y-10">
			<div>
				<h3 class="font-serif font-normal text-[1.3rem] mb-2">A decade in regulated industries.</h3>
				<p class="text-[0.95rem] text-fg-dim leading-[1.7]">
					We've shipped AI products in healthcare, legal tech, fintech, and insurance — sectors where
					compliance isn't optional and getting it wrong has real consequences. That experience shapes
					everything we do.
				</p>
			</div>

			<div>
				<h3 class="font-serif font-normal text-[1.3rem] mb-2">Decision-making rigour from aviation.</h3>
				<p class="text-[0.95rem] text-fg-dim leading-[1.7]">
					Our founder is a former commercial pilot. The DODAR framework we use — Diagnose, Options,
					Decide, Action, Review — comes from Crew Resource Management. It means we think before we
					build, and we build what actually matters.
				</p>
			</div>

			<div>
				<h3 class="font-serif font-normal text-[1.3rem] mb-2">Technical depth, business language.</h3>
				<p class="text-[0.95rem] text-fg-dim leading-[1.7]">
					We speak both. Your board gets a clear recommendation. Your dev team gets architecture that
					works. Nobody gets jargon they don't need.
				</p>
			</div>
		</div>
	</section>

	<!-- What People Say -->
	<section class="py-16 border-b border-border">
		<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
			What people say
			<span class="flex-1 h-px bg-border"></span>
		</div>

		<div class="space-y-6">
			{testimonials.map((t) => (
				<div class="border-l-2 border-accent pl-6 py-1">
					<p class="font-serif text-[1.1rem] text-fg leading-[1.5] mb-2">
						&ldquo;{t.quote}&rdquo;
					</p>
					<p class="text-[0.9rem]">
						<span class="text-fg-dim">&mdash; {t.name}, {t.role}</span>
					</p>
				</div>
			))}
		</div>
	</section>

	<!-- From the Founder -->
	<section class="py-16 border-b border-border">
		<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
			From the founder
			<span class="flex-1 h-px bg-border"></span>
		</div>

		<p class="text-[0.95rem] text-fg-dim leading-[1.8] mb-4">
			Crox was founded by Adam Field — a product leader, former commercial pilot, and builder who's
			spent a decade shipping products where compliance is mandatory and safety is critical.
		</p>
		<a href="/about" class="text-[0.95rem] text-accent no-underline hover:text-fg transition-colors">
			More about Adam and why Crox exists &rarr;
		</a>
	</section>

	<!-- Let's Talk -->
	<section class="py-24">
		<h2 class="font-serif font-normal text-[2rem] leading-[1.2] mb-6 max-sm:text-[1.6rem]">
			Ready to connect AI to your <em class="italic text-accent">business?</em>
		</h2>
		<p class="text-[0.95rem] text-fg-dim leading-[1.8] mb-10">
			Tell us what tools your team uses and we'll show you what's possible in two weeks.
		</p>
		<div class="flex gap-6 items-center max-sm:flex-col max-sm:items-start">
			<a
				href="/ai-integration"
				class="inline-block font-mono text-[0.8rem] font-medium tracking-[0.15em] uppercase text-fg bg-accent px-10 py-4 transition-all hover:bg-[#c4472e] hover:-translate-y-px no-underline"
			>
				Start your AI Integration Sprint &rarr;
			</a>
			<a
				href="mailto:adam@crox.io"
				class="text-[0.95rem] text-fg no-underline border-b border-border pb-px hover:border-accent transition-colors"
			>
				adam@crox.io &rarr;
			</a>
		</div>
	</section>
</Base>

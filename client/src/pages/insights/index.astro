---
import Base from '../../layouts/Base.astro';
import BlogFaqAccordion from '../../components/BlogFaqAccordion.tsx';
import { blogPosts } from '../../content/blogPosts';

const baseUrl = 'https://crox.io';
const canonicalUrl = `${baseUrl}/insights`;

const faqs = [
	{
		question: 'How do I connect ChatGPT to my accounting software?',
		answer: 'You can connect ChatGPT to accounting software like Xero, QuickBooks, or FreshBooks using Model Context Protocol (MCP) servers. These act as bridges that let Claude access your financial data, create invoices, and reconcile accounts without direct API access.',
	},
	{
		question: 'Can AI access my business data safely?',
		answer: 'Yes, with proper safeguards. MCP servers provide secure access patterns where AI only gets the data it needs, your credentials stay on your servers, and you maintain complete control over what information is shared. This is much safer than giving AI full database access.',
	},
	{
		question: 'What is the cheapest way to integrate AI with my small business tools?',
		answer: 'Using existing MCP servers is the most cost-effective approach. Open-source servers for common tools are free, while custom integrations start around the cost of a few developer days. No expensive infrastructure or licensing required.',
	},
	{
		question: 'Do I need a developer to set up AI for my business?',
		answer: 'Not necessarily. Many integrations can be configured through Claude itself or simple configuration files. For custom setups with proprietary systems, you might need a developer, but standard business tools typically work out of the box.',
	},
	{
		question: 'How long does it take to connect AI to Xero or HubSpot?',
		answer: 'For standard integrations like Xero or HubSpot, you can get up and running in hours. Initial setup takes about 1-2 hours, then you can immediately start using Claude with your data. Complex workflows might take a day or two to optimize.',
	},
];

const sortedPosts = [...blogPosts].sort((a, b) => {
	const dateA = a.dateISO || '1970-01-01';
	const dateB = b.dateISO || '1970-01-01';
	return dateB.localeCompare(dateA);
});

const collectionPageSchema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: 'Insights — Crox',
	description: 'Insights and guides on AI integration for business.',
	url: canonicalUrl,
	isPartOf: {
		'@type': 'Website',
		name: 'Crox',
		url: baseUrl,
	},
};

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: baseUrl },
		{ '@type': 'ListItem', position: 2, name: 'Insights', item: canonicalUrl },
	],
};

const itemListSchema = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	name: "Insights",
	url: canonicalUrl,
	itemListElement: sortedPosts.map((post, index) => ({
		'@type': 'Article',
		position: index + 1,
		name: post.title,
		description: post.description,
		url: `${baseUrl}/insights/${post.slug}`,
	})),
};

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqs.map(faq => ({
		'@type': 'Question',
		name: faq.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: faq.answer,
		},
	})),
};

const jsonLd = [collectionPageSchema, breadcrumbSchema, itemListSchema, faqSchema];
---

<Base
	title="Insights — Crox"
	description="Insights and guides on AI integration for business. Learn how to safely connect AI to your tools."
	canonical={canonicalUrl}
	jsonLd={jsonLd}
>
	<div class="w-full max-w-[900px] mx-auto px-4 sm:px-6 py-16 sm:py-24">
		<!-- Hero Section -->
		<header class="mb-16">
			<div class="grid grid-cols-1 md:grid-cols-[1fr_280px] gap-8 lg:gap-12 items-stretch">
				<div>
					<h1 class="font-serif font-normal text-[3.2rem] leading-[1.15] text-fg mb-4">
						Insights
					</h1>
					<p class="text-[1.1rem] text-fg-dim leading-[1.8]">
						Practical guides and analysis on integrating AI with your business tools. Learn how Model Context Protocol is making it safe and accessible for SMEs to connect their AI assistants to the systems they already use.
					</p>
				</div>
				<div class="hidden md:block relative bg-surface border border-border overflow-hidden">
					<svg viewBox="0 0 300 220" style="position: absolute; inset: 0; width: 100%; height: 100%;" preserveAspectRatio="xMidYMid slice">
					  <g transform="translate(110, 110)">
					    <circle cx="0" cy="0" r="100" fill="none" stroke="#332e2b" stroke-width="1"/>
					    <circle cx="0" cy="0" r="75" fill="none" stroke="#332e2b" stroke-width="1"/>
					    <circle cx="0" cy="0" r="50" fill="none" stroke="#332e2b" stroke-width="1"/>
					    <circle cx="0" cy="0" r="25" fill="none" stroke="#332e2b" stroke-width="1"/>
					    <line x1="-105" y1="0" x2="105" y2="0" stroke="#5a5550" stroke-width="0.5"/>
					    <line x1="0" y1="-105" x2="0" y2="105" stroke="#5a5550" stroke-width="0.5"/>
					    <path d="M 0,0 L 100,0 A 100,100 0 0 0 70.7,-70.7 Z" fill="#e07070" opacity="0.25"/>
					    <line x1="0" y1="0" x2="100" y2="0" stroke="#e07070" stroke-width="2.5"/>
					    <circle cx="45" cy="-15" r="4" fill="#e07070"/>
					    <circle cx="45" cy="-15" r="9" fill="none" stroke="#e07070" stroke-width="1" opacity="0.5"/>
					    <circle cx="65" cy="-45" r="3" fill="#c4472e"/>
					    <circle cx="80" cy="-10" r="3" fill="#e07070"/>
					    <circle cx="-30" cy="40" r="2" fill="#5a5550"/>
					    <circle cx="-60" cy="-20" r="2" fill="#5a5550"/>
					  </g>
					  <text x="225" y="50" font-family="DM Mono, monospace" font-size="11" font-weight="500" fill="#e07070" letter-spacing="2">SIGNAL</text>
					  <line x1="225" y1="58" x2="285" y2="58" stroke="#e07070" stroke-width="2"/>
					  <text x="225" y="80" font-family="DM Mono, monospace" font-size="36" font-weight="500" fill="#e8e4de" letter-spacing="1">03</text>
					  <text x="225" y="96" font-family="DM Mono, monospace" font-size="7" fill="#d0cbc5" letter-spacing="2">DETECTED</text>
					  <g font-family="DM Mono, monospace" font-size="8" letter-spacing="1">
					    <text x="225" y="130" fill="#d0cbc5">▸ TREND.A</text>
					    <text x="225" y="148" fill="#d0cbc5">▸ TREND.B</text>
					    <text x="225" y="166" fill="#d0cbc5">▸ NOISE</text>
					  </g>
					  <text x="20" y="208" font-family="DM Mono, monospace" font-size="7" fill="#5a5550" letter-spacing="2">SCAN · 05.15.26 · 14:42 UTC</text>
					</svg>
				</div>
			</div>
		</header>

		<!-- Insights List -->
		<div class="space-y-8 mb-16">
			{sortedPosts.map((post) => (
				<a
					href={`/insights/${post.slug}`}
					class="block group"
				>
					<article class="border border-border p-6 sm:p-8 hover:border-accent transition-colors duration-300 bg-surface/30">
						<div class="flex flex-col">
							<h2 class="font-serif font-normal text-[1.6rem] text-fg group-hover:text-accent transition-colors mb-2">
								{post.title}
							</h2>
							<p class="text-[0.95rem] text-fg-dim mb-4 leading-[1.6]">
								{post.subtitle}
							</p>

							<div class="flex flex-wrap items-center gap-4 text-[0.8rem] text-fg-dim mb-4">
								<span>{post.date}</span>
								<span>&bull;</span>
								<span>{post.readTime}</span>
							</div>

							{post.tags.length > 0 && (
								<div class="flex flex-wrap gap-2">
									{post.tags.map((tag) => (
										<span
											class="inline-block text-[0.75rem] tracking-[0.1em] uppercase text-fg-dim border border-border/50 px-3 py-1"
										>
											{tag}
										</span>
									))}
								</div>
							)}
						</div>
					</article>
				</a>
			))}
		</div>

		<!-- FAQ Section -->
		<div class="mb-16">
			<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
				FAQ
				<span class="flex-1 h-px bg-border"></span>
			</div>
			<BlogFaqAccordion faqs={faqs} client:load />
		</div>

		<!-- CTA Section -->
		<div class="bg-surface border border-border p-8 sm:p-10">
			<h2 class="font-serif font-normal text-[1.6rem] text-fg mb-4">
				Ready to implement AI in your business?
			</h2>
			<p class="text-[0.95rem] text-fg-dim leading-[1.8] mb-6">
				Discuss how Model Context Protocol can safely connect your AI assistant to your business systems. Book a call with our team.
			</p>
			<a
				href="https://calendar.app.google/3avUXyXnctfWpyHF7"
				target="_blank"
				rel="noopener noreferrer"
				class="inline-block font-mono text-[0.8rem] font-medium tracking-[0.15em] uppercase text-fg bg-accent px-10 py-4 hover:opacity-90 transition-opacity"
			>
				Book a Call <span class="sr-only">(opens in a new tab)</span>
			</a>
		</div>
	</div>
</Base>

---
import Base from '../layouts/Base.astro';

const jsonLd = [
	{
		'@context': 'https://schema.org',
		'@type': 'Service',
		name: 'Board / Exec AI Advisory',
		description: 'Briefings, working sessions, and ongoing guidance for boards and exec teams making decisions about AI adoption in regulated environments.',
		provider: { '@type': 'Organization', name: 'Crox', url: 'https://crox.io' },
		url: 'https://crox.io/board-exec',
		areaServed: 'GB',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://crox.io' },
			{ '@type': 'ListItem', position: 2, name: 'Board / Exec', item: 'https://crox.io/board-exec' },
		],
	},
];
---

<Base
	title="Board & Exec AI Advisory — Independent guidance for senior leaders | Crox"
	description="Briefings, working sessions, and ongoing guidance for boards and exec teams making decisions about AI adoption in regulated environments."
	canonical="https://crox.io/board-exec"
	jsonLd={jsonLd}
>
	<!-- Hero -->
	<div class="py-24 pb-16 border-b border-border">
		<div class="grid grid-cols-1 md:grid-cols-[1fr_280px] gap-8 lg:gap-12 items-stretch">
			<div>
				<p class="font-mono text-[0.7rem] tracking-[0.2em] uppercase text-accent mb-6">Service</p>
				<h1 class="font-serif font-normal text-[3.2rem] leading-[1.15] mb-8 max-sm:text-[2.2rem]">
					Board / <em class="italic text-accent">Exec.</em>
				</h1>
				<p class="text-[1rem] text-fg-dim leading-[1.8] mb-10">
					Briefings, working sessions, and ongoing guidance for the people deciding what AI does
					in your organisation.
				</p>
				<div class="flex flex-wrap gap-x-8 gap-y-3 mb-10 font-mono text-[0.85rem]">
					<span class="text-fg-dim">Board, exec team, or leadership group</span>
					<span class="text-fg-dim">Single session or programme</span>
				</div>
				<a
					href="https://calendar.app.google/dmmq9bdFyc11G8Km8"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-block font-mono text-[0.8rem] font-medium tracking-[0.15em] uppercase text-fg bg-accent px-10 py-4 transition-all hover:bg-[#c4472e] hover:-translate-y-px no-underline"
				>
					Book a call to discuss &rarr;
				</a>
			</div>
			<div class="hidden md:block relative bg-surface border border-border overflow-hidden">
				<svg viewBox="0 0 300 220" style="position: absolute; inset: 0; width: 100%; height: 100%;" preserveAspectRatio="xMidYMid slice">
				  <rect x="200" y="-10" width="120" height="60" fill="#c4472e" transform="rotate(4, 260, 20)"/>
				  <text x="260" y="28" font-family="DM Mono, monospace" font-size="11" font-weight="500" fill="#12100e" text-anchor="middle" letter-spacing="2" transform="rotate(4, 260, 28)">CLASSIFIED</text>
				  <g font-family="DM Mono, monospace" font-size="8" letter-spacing="1">
				    <rect x="20" y="70" width="80" height="26" fill="none" stroke="#e07070" stroke-width="2.5"/>
				    <text x="60" y="87" fill="#e07070" text-anchor="middle" font-weight="500">DECISION</text>
				    <line x1="100" y1="83" x2="140" y2="50" stroke="#e07070" stroke-width="2"/>
				    <line x1="100" y1="83" x2="140" y2="120" stroke="#c4472e" stroke-width="2"/>
				    <line x1="100" y1="83" x2="140" y2="185" stroke="#9d6b53" stroke-width="2"/>
				    <rect x="140" y="38" width="80" height="24" fill="#1a1716" stroke="#e07070" stroke-width="2"/>
				    <text x="180" y="53" fill="#d0cbc5" text-anchor="middle">A · INVEST</text>
				    <text x="225" y="53" fill="#e07070" font-weight="500">↗</text>
				    <rect x="140" y="108" width="80" height="24" fill="#1a1716" stroke="#c4472e" stroke-width="2"/>
				    <text x="180" y="123" fill="#d0cbc5" text-anchor="middle">B · DEFER</text>
				    <text x="225" y="123" fill="#c4472e">→</text>
				    <rect x="140" y="173" width="80" height="24" fill="#1a1716" stroke="#5a5550" stroke-width="2" stroke-dasharray="3,2"/>
				    <text x="180" y="188" fill="#d0cbc5" text-anchor="middle" opacity="0.6">C · REJECT</text>
				    <text x="225" y="188" fill="#5a5550">↘</text>
				  </g>
				  <text x="20" y="200" font-family="DM Mono, monospace" font-size="8" fill="#5a5550" letter-spacing="2">DOC.B-04 · BRIEF · 05.26</text>
				  <g stroke="#e07070" stroke-width="1.5" fill="none">
				    <line x1="10" y1="10" x2="25" y2="10"/>
				    <line x1="10" y1="10" x2="10" y2="25"/>
				  </g>
				</svg>
			</div>
		</div>
	</div>

	<!-- Problem -->
	<section class="py-16 border-b border-border">
		<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
			The problem this solves
			<span class="flex-1 h-px bg-border"></span>
		</div>

		<div class="text-[0.95rem] text-fg-dim leading-[1.8] space-y-4">
			<p>
				Your board is asking sharper questions about AI than they were a year ago. Your exec
				team is being lobbied by vendors, internal champions, and external pressure. Most of
				what's being said is either too technical to act on or too vague to trust.
			</p>
			<p class="text-fg">
				You need someone in the room who has done this before, in regulated environments,
				and can speak to a board without translating through a vendor's slide deck.
			</p>
		</div>
	</section>

	<!-- What you get -->
	<section class="py-16 border-b border-border">
		<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
			What you get
			<span class="flex-1 h-px bg-border"></span>
		</div>

		<ul class="space-y-4">
			<li class="text-[0.95rem] text-fg-dim leading-[1.7] pl-4 border-l-2 border-accent">
				Briefings tailored to your board or exec team — not generic AI 101
			</li>
			<li class="text-[0.95rem] text-fg-dim leading-[1.7] pl-4 border-l-2 border-accent">
				Working sessions that move decisions forward, not just inform
			</li>
			<li class="text-[0.95rem] text-fg-dim leading-[1.7] pl-4 border-l-2 border-accent">
				Direct, plain-language answers to the questions your team is actually asking
			</li>
			<li class="text-[0.95rem] text-fg-dim leading-[1.7] pl-4 border-l-2 border-accent">
				Optional ongoing engagement: regular check-ins, decision support, or board-level advisory
			</li>
		</ul>
	</section>

	<!-- How it works -->
	<section class="py-16 border-b border-border">
		<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
			How it works
			<span class="flex-1 h-px bg-border"></span>
		</div>

		<p class="text-[0.95rem] text-fg-dim leading-[1.8] mb-10">
			Three common shapes. We'll pick the right one for you in the conversation.
		</p>

		<div class="space-y-10">
			<div>
				<h3 class="font-serif font-normal text-[1.3rem] mb-2">Single board briefing</h3>
				<p class="text-[0.95rem] text-fg-dim leading-[1.7]">
					60–90 minutes. Tailored to your board's specific questions. Pre-read prepared in advance.
				</p>
			</div>

			<div>
				<h3 class="font-serif font-normal text-[1.3rem] mb-2">Exec working session</h3>
				<p class="text-[0.95rem] text-fg-dim leading-[1.7]">
					Half day. Used for a specific decision: build vs. buy, vendor selection, governance setup.
				</p>
			</div>

			<div>
				<h3 class="font-serif font-normal text-[1.3rem] mb-2">Ongoing advisory</h3>
				<p class="text-[0.95rem] text-fg-dim leading-[1.7]">
					Monthly cadence. Standing slot for decisions, escalations, and board prep.
				</p>
			</div>
		</div>
	</section>

	<!-- Who this is for -->
	<section class="py-16 border-b border-border">
		<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
			Is this for you?
			<span class="flex-1 h-px bg-border"></span>
		</div>

		<div class="grid grid-cols-2 gap-8 max-sm:grid-cols-1">
			<div>
				<h3 class="font-serif font-normal text-[1.2rem] mb-4">Right for you if</h3>
				<ul class="space-y-3">
					<li class="text-[0.95rem] text-fg-dim leading-[1.7] pl-4 border-l-2 border-accent">
						You're at board, C-suite, or senior leadership level and AI is now a recurring agenda item
					</li>
					<li class="text-[0.95rem] text-fg-dim leading-[1.7] pl-4 border-l-2 border-accent">
						Your team needs an external voice to credentialise (or push back on) internal recommendations
					</li>
					<li class="text-[0.95rem] text-fg-dim leading-[1.7] pl-4 border-l-2 border-accent">
						You operate in a regulated sector and need someone fluent in both the technology and the constraints
					</li>
				</ul>
			</div>
			<div>
				<h3 class="font-serif font-normal text-[1.2rem] mb-4">Not right if</h3>
				<ul class="space-y-3">
					<li class="text-[0.95rem] text-fg-dim leading-[1.7] pl-4 border-l-2 border-border">
						You're looking for hands-on implementation (start with <a href="/experiments" class="text-accent no-underline hover:text-fg">Experiments</a>)
					</li>
					<li class="text-[0.95rem] text-fg-dim leading-[1.7] pl-4 border-l-2 border-border">
						You want a vendor pitch rather than independent guidance
					</li>
				</ul>
			</div>
		</div>
	</section>

	<!-- Proof -->
	<section class="py-16 border-b border-border">
		<div class="text-[0.7rem] tracking-[0.2em] uppercase text-fg-dim mb-8 flex items-center gap-4">
			Proof
			<span class="flex-1 h-px bg-border"></span>
		</div>

		<div class="border-l-2 border-accent pl-6 py-1">
			<p class="font-serif text-[1.3rem] text-fg leading-[1.5] mb-3">
				&ldquo;Adam cares deeply about the quality and impact of his work.&rdquo;
			</p>
			<p class="text-[0.9rem] text-fg-dim">&mdash; Jasel Mehta, COO</p>
		</div>
	</section>

	<!-- CTA -->
	<section class="py-24">
		<h2 class="font-serif font-normal text-[2rem] leading-[1.2] mb-6 max-sm:text-[1.6rem]">
			Get the right voice in the <em class="italic text-accent">room.</em>
		</h2>
		<p class="text-[0.95rem] text-fg-dim leading-[1.8] mb-10">
			Tell us what's on the agenda. We'll tell you the right shape of engagement for it.
		</p>
		<a
			href="https://calendar.app.google/dmmq9bdFyc11G8Km8"
			target="_blank"
			rel="noopener noreferrer"
			class="inline-block font-mono text-[0.8rem] font-medium tracking-[0.15em] uppercase text-fg bg-accent px-10 py-4 transition-all hover:bg-[#c4472e] hover:-translate-y-px no-underline"
		>
			Book a call to discuss &rarr;
		</a>
	</section>
</Base>
